    style RELAY fill:#FCE4EC,stroke:#C62828,stroke-width:2px,color:#B71C1C
    style ZB fill:#E8F5E9,stroke:#2E7D32,stroke-width:1px
    style SQL fill:#E0F2F1,stroke:#00695C,stroke-width:1px
    style T1 fill:#FFFFFF,stroke:#2E7D32,stroke-width:1px
    style T2 fill:#FFFFFF,stroke:#2E7D32,stroke-width:1px
    style T3 fill:#FFFFFF,stroke:#2E7D32,stroke-width:1px
